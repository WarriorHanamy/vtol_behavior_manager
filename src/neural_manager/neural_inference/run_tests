#!/usr/bin/env python3
"""
Test runner wrapper for neural_pos_ctrl TDD workflow.

This script handles environment switching between:
1. ROS2 build environment (system Python at /opt/ros/humble)
2. TensorRT virtual environment (uv-managed venv)

Usage:
    ./run_tests                    # Auto-detect environment
    ./run_tests --env onnx         # Force ONNX/ROS2 environment
    ./run_tests --env tensorrt     # Force TensorRT environment
    ./run_tests --unit --cov       # Run unit tests with coverage
    ./run_tests --integration      # Run integration tests
    ./run_tests --no-gpu           # Skip GPU tests
"""

import os
import sys
import argparse
import subprocess
from pathlib import Path
from typing import Optional, List


# =============================================================================
# ANSI Color Codes
# =============================================================================

class Colors:
    GREEN = "\033[92m"      # Success green
    YELLOW = "\033[93m"     # Warning yellow
    BLUE = "\033[94m"       # Info blue
    RED = "\033[91m"        # Error red
    BOLD = "\033[1m"        # Bold text
    RESET = "\033[0m"       # Reset formatting
    CHECKMARK = "\u2713"    # ✓ symbol


def color_print(text: str, color: str = Colors.RESET) -> None:
    """Print text with ANSI color formatting."""
    print(f"{color}{text}{Colors.RESET}")


# =============================================================================
# Path Configuration
# =============================================================================

PROJECT_ROOT = Path(__file__).parent.absolute()
ROS_PYTHON_PATHS = [
    Path("/opt/ros/humble"),
    Path("/opt/ros/iron"),
    Path("/opt/ros/jazzy"),
]
UV_VENV_PATH = PROJECT_ROOT / ".venv_tensorrt"


# =============================================================================
# ROS2 Environment Setup
# =============================================================================

def setup_ros2_environment(env: dict) -> dict:
    """
    Source ROS2 setup.bash and update environment variables.

    Args:
        env: Dictionary of environment variables to update in-place

    Returns:
        Updated environment dictionary
    """
    for ros_path in ROS_PYTHON_PATHS:
        setup_file = ros_path / "setup.bash"
        if setup_file.exists():
            try:
                # Source the setup.bash script and capture environment variables
                result = subprocess.run(
                    ["bash", "-c", f"source {setup_file} && env"],
                    capture_output=True,
                    text=True,
                    check=False
                )
                if result.returncode == 0:
                    # Parse the output and update the environment
                    for line in result.stdout.splitlines():
                        if "=" in line:
                            key, value = line.split("=", 1)
                            env[key] = value
                    color_print(f"  ROS2 sourced from: {ros_path}", Colors.GREEN)
                    return env
            except (subprocess.SubprocessError, FileNotFoundError):
                pass

    color_print("  Warning: ROS2 setup.bash not found", Colors.YELLOW)
    return env


# =============================================================================
# Environment Detection
# =============================================================================

def detect_environment() -> str:
    """
    Auto-detect current Python environment.

    Returns:
        "tensorrt" if in TensorRT venv, "onnx" otherwise
    """
    # Check if we're in a uv-managed venv
    venv_marker = Path(sys.prefix) / "pyvenv.cfg"
    if venv_marker.exists():
        # Check if TensorRT is available
        try:
            import tensorrt as trt
            return "tensorrt"
        except ImportError:
            pass

    # Check for TensorRT in current environment
    try:
        import tensorrt as trt
        return "tensorrt"
    except ImportError:
        return "onnx"


def get_python_executable(env: str) -> Path:
    """
    Get the Python executable for the specified environment.

    Args:
        env: Environment type ("onnx" or "tensorrt")

    Returns:
        Path to Python executable

    Raises:
        FileNotFoundError: If Python executable not found
    """
    if env == "tensorrt":
        # Check for uv-managed venv
        if UV_VENV_PATH.exists():
            python_path = UV_VENV_PATH / "bin" / "python"
            if python_path.exists():
                return python_path

        # Fall back to current Python
        return Path(sys.executable)
    else:
        # Use system Python (ROS2 environment)
        return Path(sys.executable)


# =============================================================================
# Test Execution
# =============================================================================

def build_pytest_args(args: argparse.Namespace) -> List[str]:
    """
    Build pytest arguments from command line arguments.

    Args:
        args: Parsed command line arguments

    Returns:
        List of pytest arguments
    """
    pytest_args = []

    # Add test selection
    if args.unit:
        pytest_args.extend(["-m", "unit or (not integration and not performance)"])
    elif args.integration:
        pytest_args.extend(["-m", "integration"])
    elif args.performance:
        pytest_args.extend(["-m", "performance"])
    elif args.all:
        pytest_args.extend([])  # Run all tests

    # Skip GPU tests if requested
    if args.no_gpu:
        pytest_args.extend(["-m", "not gpu"])

    # Skip TensorRT tests if requested
    if args.no_tensorrt:
        pytest_args.extend(["-m", "not tensorrt"])

    # Coverage
    if args.cov:
        pytest_args.extend([
            "--cov=infer_utils",
            "--cov-report=term-missing",
            "--cov-report=html:htmlcov"
        ])
        if args.cov_fail_under:
            pytest_args.append(f"--cov-fail-under={args.cov_fail_under}")

    # Verbose output
    if args.verbose:
        pytest_args.append("-vv")
    else:
        pytest_args.append("-v")

    # Additional pytest arguments
    pytest_args.extend(args.pytest_args)

    return pytest_args


def run_tests(env: str, pytest_args: List[str]) -> int:
    """
    Run pytest in specified environment.

    Args:
        env: Environment type ("onnx" or "tensorrt")
        pytest_args: Arguments to pass to pytest

    Returns:
        Exit code from pytest
    """
    python_exe = get_python_executable(env)

    # Setup environment
    env_vars = os.environ.copy()
    env_vars["PYTHONPATH"] = str(PROJECT_ROOT)
    env_vars["INFER_BACKEND"] = env

    # Setup ROS2 if using onnx environment
    if env == "onnx":
        setup_ros2_environment(env_vars)

    # Build command
    cmd = [str(python_exe), "-m", "pytest"] + pytest_args

    # Display status
    color_print(f"\n{'='*60}", Colors.BLUE)
    color_print(f"neural_pos_ctrl Test Runner", Colors.BOLD + Colors.BLUE)
    color_print(f"{'='*60}", Colors.BLUE)
    color_print(f"  Project Root: {PROJECT_ROOT}", Colors.BLUE)
    color_print(f"  Environment:  {env.upper()}", Colors.GREEN)
    color_print(f"  Python:       {python_exe}", Colors.BLUE)
    color_print(f"  Command:      pytest {' '.join(pytest_args)}", Colors.BLUE)
    color_print(f"{'='*60}\n", Colors.BLUE)

    # Execute pytest
    try:
        result = subprocess.run(
            cmd,
            cwd=PROJECT_ROOT,
            env=env_vars,
            stdin=subprocess.DEVNULL if not sys.stdin.isatty() else None
        )
        return result.returncode
    except FileNotFoundError:
        color_print(f"Error: {python_exe} not found", Colors.RED + Colors.BOLD)
        return 1
    except KeyboardInterrupt:
        color_print("\n\nTest run interrupted by user", Colors.YELLOW)
        return 130


# =============================================================================
# Command Line Interface
# =============================================================================

def parse_arguments() -> argparse.Namespace:
    """
    Parse command line arguments.

    Returns:
        Parsed arguments
    """
    parser = argparse.ArgumentParser(
        description="Test runner wrapper for neural_pos_ctrl TDD workflow",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  ./run_tests                    # Auto-detect environment
  ./run_tests --env onnx         # Force ONNX/ROS2 environment
  ./run_tests --env tensorrt     # Force TensorRT environment
  ./run_tests --unit --cov       # Unit tests with coverage
  ./run_tests --integration      # Integration tests only
  ./run_tests --no-gpu           # Skip GPU tests
  ./run_tests tests/unit/test_actors.py  # Run specific test file
        """
    )

    # Environment selection
    parser.add_argument(
        "--env",
        choices=["onnx", "tensorrt", "auto"],
        default="auto",
        help="Python environment to use (default: auto-detect)"
    )

    # Test selection
    test_group = parser.add_mutually_exclusive_group()
    test_group.add_argument(
        "--unit", "-u",
        action="store_true",
        help="Run unit tests only"
    )
    test_group.add_argument(
        "--integration", "-i",
        action="store_true",
        help="Run integration tests only"
    )
    test_group.add_argument(
        "--performance", "-p",
        action="store_true",
        help="Run performance tests only"
    )
    test_group.add_argument(
        "--all", "-a",
        action="store_true",
        help="Run all tests (default)"
    )

    # Test filters
    parser.add_argument(
        "--no-gpu",
        action="store_true",
        help="Skip tests requiring GPU"
    )
    parser.add_argument(
        "--no-tensorrt",
        action="store_true",
        help="Skip tests requiring TensorRT"
    )

    # Coverage
    parser.add_argument(
        "--cov", "-c",
        action="store_true",
        help="Enable coverage reporting"
    )
    parser.add_argument(
        "--cov-fail-under",
        type=int,
        default=80,
        help="Coverage fail threshold (default: 80)"
    )

    # Output
    parser.add_argument(
        "--verbose", "-v",
        action="store_true",
        help="Verbose output"
    )

    # Additional pytest arguments
    parser.add_argument(
        "pytest_args",
        nargs=argparse.REMAINDER,
        default=[],
        help="Additional arguments to pass to pytest"
    )

    return parser.parse_args()


def main() -> int:
    """Main entry point."""
    args = parse_arguments()

    # Determine environment
    if args.env == "auto":
        env = detect_environment()
    else:
        env = args.env

    # Build pytest arguments
    pytest_args = build_pytest_args(args)

    # Run tests
    exit_code = run_tests(env, pytest_args)

    return exit_code


if __name__ == "__main__":
    sys.exit(main())
