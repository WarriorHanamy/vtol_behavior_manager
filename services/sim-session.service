[Unit]
Description=VTOL Simulation Session (Docker Compose)

After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/rec/server/vtol-interface

ExecStart=/bin/sh -c '\
  echo "========================================"; \
  echo "Starting VTOL Simulation Session"; \
  echo "========================================"; \
   docker compose up -d --remove-orphans px4 qgc bht && \
  echo ""; \
  echo "✓ Containers started:"; \
  docker compose ps --format "table {{.Name}}\t{{.Status}}"; \
  echo ""; \
  echo "Starting neural executor..."; \
  systemctl --user start neural.target && \
  echo "✓ Neural executor started"; \
  echo ""; \
   echo "To enter bht container: docker compose attach bht"; \
  echo "To exit container (keep running): Ctrl+P Ctrl+Q"; \
  echo "========================================"'

ExecStop=/bin/sh -c '\
  echo "========================================"; \
  echo "Stopping VTOL Simulation Session"; \
  echo "========================================"; \
  echo "Stopping dependent services..."; \
  systemctl --user stop neural.target test.target 2>/dev/null || true; \
  echo "Stopping containers..."; \
  docker compose down --remove-orphans; \
  echo "✓ Simulation stopped"; \
  echo "========================================"'

[Install]
WantedBy=default.target
